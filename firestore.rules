rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} - profile is readable by any signed-in user (needed for
    // search, chat headers, contact lists); only the owner can write it.
    match /users/{uid} {
      allow get, list: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      match /blocked/{blockedId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // usernames/{username} -> { uid, email } is a public directory used to
    // resolve "login by username" before the user is authenticated, and to
    // enforce username uniqueness at signup. Direct-ID reads only (no list),
    // so it can't be enumerated wholesale - this mirrors the standard
    // trade-off of username+email auth without a backend.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      allow update: if false;
    }

    // contacts/{uidA_uidB} - either side of the relationship can read/act on it.
    match /contacts/{pairId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    // chats/{chatId} - only participants can see or touch a chat.
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // messages/{messageId} - readable/writable by chat participants.
      // Note: Firestore rules can't restrict individual fields (e.g. "only
      // the sender may edit `content`, but any participant may edit
      // `reactions`) without Cloud Functions. That finer-grained enforcement
      // lives in the app's UI here; harden with a Cloud Function trigger if
      // you need it enforced server-side too.
      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.senderId &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow delete: if false; // deletion is a soft-delete via update (deletedAt field)
      }

      match /typing/{uid} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // groupInvites/{id} - readable/joinable by any signed-in user who has the code.
    match /groupInvites/{inviteId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
  }
}
